{
  "compilerOptions": {
    "target": "es6",// Cho phép biên dịch code TS sang ES6
    "module": "commonjs",//CommonJS là tiêu chuẩn được sử dụng trong Node.js để làm việc với module
    "removeComments": true, //Xóa comments khi biên dịch sang js
    "esModuleInterop": true //Dùng từ khóa import thay cho require
  }

}